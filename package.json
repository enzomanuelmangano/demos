{
  "name": "demos",
  "version": "0.2.5",
  "main": "expo-router/entry",
  "reanimated": {
    "staticFeatureFlags": {
      "DISABLE_COMMIT_PAUSING_MECHANISM": true,
      "USE_COMMIT_HOOK_ONLY_FOR_REACT_COMMITS": true,
      "ANDROID_SYNCHRONOUSLY_UPDATE_UI_PROPS": true
    }
  },
  "scripts": {
    "postinstall": "node scripts/patch-skia-webgpu-android.js",
    "start": "expo start",
    "dev": "node scripts/start-with-animation.js",
    "android": "expo run:android",
    "ios": "expo run:ios --device",
    "web": "expo start --web",
    "e2e": "mkdir -p .maestro/artifacts && npx @reactiive/ennio test .maestro/animations/ --disable-reuse-app",
    "e2e:one": "npx @reactiive/ennio test --disable-reuse-app",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "bun eslint --fix 'app/**/*.ts' 'app/**/*.tsx' 'src/**/*.ts' 'src/**/*.tsx'",
    "prettier-format": "prettier --write 'app/**/*.ts' 'app/**/*.tsx' 'src/**/*.ts' 'src/**/*.tsx'",
    "prebuild": "npx expo prebuild --clean",
    "build:ios:dev": "eas build --profile development --platform=ios --auto-submit --no-wait",
    "build:ios": "eas build --profile production --platform=ios --auto-submit --no-wait",
    "submit:ios:dev": "eas submit --profile development --platform=ios",
    "submit:ios": "eas submit --profile production --platform=ios",
    "generate-icons-set": "cd scripts/generate-app-icon && bun install && bun generate-icons",
    "eas-build-pre-install": "bun generate-icons-set --value=$(node scripts/utils/get-animations-count.js)",
    "clean": "rimraf node_modules ios android $TMPDIR/haste-map-* $TMPDIR/metro-cache .expo && bun pm cache clean && watchman watch-del-all",
    "download-mosaic-photos": "bun scripts/download-mosaic-photos.ts",
    "generate-sprite-atlas": "bun scripts/generate-sprite-atlas.ts",
    "update-expo-packages": "expo install --fix",
    "ota:dev": "eas update --channel development",
    "ota": "eas update --channel production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~56.0.14",
    "@expo/ui": "~56.0.16",
    "@expo/vector-icons": "^15.0.3",
    "@legendapp/list": "3.0.3",
    "@react-native-masked-view/masked-view": "0.3.2",
    "@react-native-menu/menu": "^2.0.0",
    "@react-native-seoul/masonry-list": "^1.4.2",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/drawer": "^7.10.3",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "@shopify/react-native-skia": "2.6.2",
    "burnt": "^0.13.0",
    "color": "^4.2.3",
    "date-fns": "^4.1.0",
    "expo": "^56.0.0",
    "expo-asset": "~56.0.16",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "~56.0.17",
    "expo-constants": "~56.0.17",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.10",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-quick-actions": "6.0.0",
    "expo-router": "~56.2.9",
    "expo-sensors": "~56.0.5",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.18",
    "fft.js": "^4.0.4",
    "jotai": "^2.9.3",
    "lodash.debounce": "^4.0.8",
    "lottie-react-native": "~7.3.1",
    "pressto": "0.6.1",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-chessboard": "0.2.0",
    "react-native-fast-confetti": "^1.1.1",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-ios-context-menu": "^3.2.1",
    "react-native-ios-utilities": "^5.2.0",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-nitro-modules": "0.35.9",
    "react-native-pulsar": "^1.6.1",
    "react-native-qrcode-skia": "^0.3.1",
    "react-native-reanimated": "4.3.1",
    "react-native-redash": "^18.1.4",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-skia-gesture": "0.4.5-beta.1",
    "react-native-web": "^0.21.0",
    "react-native-webgpu": "0.5.14",
    "react-native-worklets": "0.8.3",
    "simplex-noise": "^4.0.3",
    "zeego": "^3.0.6"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/color": "^3.0.6",
    "@types/lodash.debounce": "^4",
    "@types/pngjs": "^6.0.5",
    "@types/qrcode": "^1.5.5",
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-plugin-react-compiler": "1.0.0",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-react-native-wcandillon": "^4.0.1",
    "eslint-plugin-deprecation": "^3.0.0",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^27.2.3",
    "eslint-plugin-local-rules": "^3.0.2",
    "eslint-plugin-pressto": "^0.1.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-refined": "^0.0.5",
    "expo-color-space-plugin": "^0.0.4",
    "nitrogen": "^0.35.9",
    "pngjs": "^7.0.0",
    "prettier": "^3.1.1",
    "rimraf": "^6.0.1",
    "sharp": "^0.33.5",
    "typescript": "~5.9.2"
  },
  "private": true,
  "packageManager": "bun@1.2.22",
  "trustedDependencies": [
    "@shopify/react-native-skia"
  ],
  "patchedDependencies": {
    "expo-modules-jsi@56.0.8": "patches/expo-modules-jsi@56.0.8.patch",
    "react-native-ios-utilities@5.2.0": "patches/react-native-ios-utilities@5.2.0.patch"
  },
  "overrides": {
    "react-native-drawer-layout": "4.2.4"
  }
}
